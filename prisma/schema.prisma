// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  STAFF
}

enum LeadStatus {
  new
  contacted
  interested
  not_interested
  converted
}

enum LeadSource {
  website
  referral
  social_media
  cold_call
  advertisement
  other
}

enum PaymentStatus {
  pending
  paid
  failed
  refunded
}

enum DeliveryStatus {
  processing
  shipped
  delivered
  cancelled
  returned
}

enum FollowUpType {
  lead_followup
  refill_followup
}

enum FollowUpStatus {
  pending
  completed
  cancelled
  snoozed
}

model User {
  id            String    @id @default(auto()) @map("_id") @db.ObjectId
  name          String
  email         String    @unique
  password      String
  role          UserRole  @default(STAFF)
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts      Account[]
  sessions      Session[]
}

model Account {
  id                String  @id @default(auto()) @map("_id") @db.ObjectId
  userId            String  @db.ObjectId
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  sessionToken String   @unique
  userId       String   @db.ObjectId
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Lead {
  id            String      @id @default(auto()) @map("_id") @db.ObjectId
  name          String
  phone         String
  email         String?
  city          String?
  source        LeadSource  @default(other)
  notes         String?
  status        LeadStatus  @default(new)
  followUpDate  DateTime?
  convertedAt   DateTime?
  customerId    String?     @db.ObjectId
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  followUps     FollowUp[]
  customer      Customer?   @relation(fields: [customerId], references: [id])
}

model Customer {
  id          String    @id @default(auto()) @map("_id") @db.ObjectId
  name        String
  phone       String
  email       String?
  address     String?
  city        String?
  tags        String[]
  notes       String?
  totalSpent  Float     @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  orders      Order[]
  followUps   FollowUp[]
  leads       Lead[]
}

model Product {
  id              String    @id @default(auto()) @map("_id") @db.ObjectId
  name            String
  variant         String?
  sku             String    @unique
  price           Float
  stock           Int       @default(0)
  description     String?
  refillCycleDays Int       @default(30)
  isActive        Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  orderItems      OrderItem[]
}

model Order {
  id              String          @id @default(auto()) @map("_id") @db.ObjectId
  orderId         String          @unique
  customerId      String          @db.ObjectId
  totalAmount     Float
  orderDate       DateTime        @default(now())
  refillDate      DateTime?
  paymentStatus   PaymentStatus   @default(pending)
  deliveryStatus  DeliveryStatus  @default(processing)
  notes           String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  customer        Customer        @relation(fields: [customerId], references: [id])
  items           OrderItem[]
  followUps       FollowUp[]
}

model OrderItem {
  id          String    @id @default(auto()) @map("_id") @db.ObjectId
  orderId     String    @db.ObjectId
  productId   String    @db.ObjectId
  quantity    Int
  price       Float
  totalPrice  Float

  order       Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product     Product   @relation(fields: [productId], references: [id])
}

model FollowUp {
  id                String          @id @default(auto()) @map("_id") @db.ObjectId
  type              FollowUpType
  title             String
  description       String?
  relatedLeadId     String?         @db.ObjectId
  relatedCustomerId String?         @db.ObjectId
  relatedOrderId    String?         @db.ObjectId
  dueDate           DateTime
  status            FollowUpStatus  @default(pending)
  notificationSent  Boolean         @default(false)
  completedAt       DateTime?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  lead              Lead?           @relation(fields: [relatedLeadId], references: [id])
  customer          Customer?       @relation(fields: [relatedCustomerId], references: [id])
  order             Order?          @relation(fields: [relatedOrderId], references: [id])
}

model Notification {
  id          String    @id @default(auto()) @map("_id") @db.ObjectId
  title       String
  message     String
  type        String
  isRead      Boolean   @default(false)
  relatedId   String?
  createdAt   DateTime  @default(now())
}
